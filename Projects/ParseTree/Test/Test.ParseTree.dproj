<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <Base>True</Base>
        <AppType>Console</AppType>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <DCC_DCCCompiler>DCC32</DCC_DCCCompiler>
        <FrameworkType>None</FrameworkType>
        <MainSource>Test.ParseTree.dpr</MainSource>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <ProjectGuid>{AABBCCDD-1122-3344-5566-778899AABBCC}</ProjectGuid>
        <ProjectName Condition="'$(ProjectName)'==''">Test.ParseTree</ProjectName>
        <ProjectVersion>20.3</ProjectVersion>
        <TargetedPlatforms>1</TargetedPlatforms>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win32)'!=''">
        <Cfg_1_Win32>true</Cfg_1_Win32>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <SanitizedProjectName>Test_ParseTree</SanitizedProjectName>
        <DCC_DcuOutput>.\Win32\$(Config)</DCC_DcuOutput>
        <DCC_DependencyCheckOutputName>Win32\$(Config)\Test.ParseTree.exe</DCC_DependencyCheckOutputName>
        <DCC_ExeOutput>.\Win32\$(Config)</DCC_ExeOutput>
        <DCC_Namespace>System;Winapi;$(DCC_Namespace)</DCC_Namespace>
        <DCC_UnitSearchPath>..\Source;..\..\..\Lib\mORMot\src\core\;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <Icon_MainIcon>$(BDS)\bin\delphi_PROJECTICON.ico</Icon_MainIcon>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
        <DCC_Optimize>false</DCC_Optimize>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1_Win32)'!=''">
        <AppDPIAwarenessMode>none</AppDPIAwarenessMode>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="..\Source\ParseTree.Core.pas"/>
        <DCCReference Include="..\Source\ParseTree.Tokens.pas"/>
        <DCCReference Include="..\Source\ParseTree.Nodes.pas"/>
        <DCCReference Include="..\Source\ParseTree.Serializer.pas"/>
        <DCCReference Include="..\Source\ParseTree.Writer.pas"/>
        <DCCReference Include="..\Source\ParseTree.Parser.pas"/>
        <DCCReference Include="..\Source\ParseTree.Lexer.pas"/>
        <DCCReference Include="..\Source\ParseTree.Visitor.pas"/>
        <DCCReference Include="Test.ParseTree.Nodes.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.pas"/>
        <DCCReference Include="Test.ParseTree.Roundtrip.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.ClassDecl.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.Statements.Loops.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.Statements.ConditionalsBlocks.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.Statements.CaseWith.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.Statements.ExceptionFlow.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.Statements.ProcCall.Basic.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.Statements.InheritedExit.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.Statements.InlineVar.pas"/>
        <DCCReference Include="Test.ParseTree.Parser.Statements.ProcCall.Advanced.pas"/>
        <DCCReference Include="Test.ParseTree.Lexer.pas"/>
        <DCCReference Include="Test.ParseTree.Visitor.pas"/>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <Import Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')" Project="$(BDS)\Bin\CodeGear.Delphi.Targets"/>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType/>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">Test.ParseTree.dpr</Source>
                </Source>
                <Excluded_Packages/>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">False</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>
