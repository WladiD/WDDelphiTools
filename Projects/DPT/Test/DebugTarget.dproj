<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{B2D8A7F1-3E4C-4A9B-8C16-5F2D9E07A341}</ProjectGuid>
        <ProjectVersion>20.2</ProjectVersion>
        <FrameworkType>None</FrameworkType>
        <MainSource>DebugTarget.dpr</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Console</AppType>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release'">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_DependencyCheckOutputName>DebugTarget.exe</DCC_DependencyCheckOutputName>
        <DCC_ExeOutput>.\$(Platform)</DCC_ExeOutput>
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_MapFile>3</DCC_MapFile>
        <DCC_RemoteDebug>true</DCC_RemoteDebug>
        <DCC_Optimize>false</DCC_Optimize>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="DebugTarget.EnumAlpha.pas"/>
        <DCCReference Include="DebugTarget.EnumBeta.pas"/>
        <DCCReference Include="DebugTarget.EnumGamma.pas"/>
        <DCCReference Include="DebugTarget.RecTypes.pas"/>
        <DCCReference Include="DebugTarget.IfaceProbe.pas"/>
        <DCCReference Include="DebugTarget.ComplexRec.pas"/>
        <DCCReference Include="DebugTarget.SharedHdr.pas"/>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Application</Borland.ProjectType>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
</Project>
